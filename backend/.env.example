# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Server port
PORT=4000

# URL of your deployed frontend (used for CORS)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Anthropic API key — required for the AI scholarship scraping agent
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Brevo (formerly Sendinblue) — transactional email
# Get your API key at https://app.brevo.com/settings/keys/api
# If not set, emails fall back to Ethereal (dev preview only)
BREVO_API_KEY=your-brevo-api-key-here

# Sender email address — must be a verified sender in your Brevo account
# Go to Brevo → Senders & IPs → Senders to add and verify this address
BREVO_FROM_EMAIL=no-reply@yourdomain.com

# Cron job secret — set this to a random string and send it as the
# X-Cron-Secret header when calling POST /api/notifications/cron-reminders
# Leave empty to disable the secret check (not recommended in production)
CRON_SECRET=replace_with_a_random_secret
