# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Server port
PORT=4000

# URL of your deployed frontend (used for CORS)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Anthropic API key — required for the AI scholarship scraping agent
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Nodemailer (for password reset / deadline reminder emails)
# Use a Gmail app password or any SMTP provider
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
